# Copy to .env (never commit). systemd unit reads these via EnvironmentFile=.

# Bearer token clients must send as Authorization: Bearer <token>
RELAY_BEARER_TOKEN=replace-me-with-a-long-random-string

# AWS region and instance ID for the dev box we control
AWS_REGION=us-east-2
DEV_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx

# SSH target — private IP works because relay sits in the same VPC
DEV_HOST=172.31.9.200
DEV_USER=ec2-user
DEV_SSH_KEY_PATH=/home/ec2-user/.ssh/relay-to-dev

# Idle thresholds (seconds/minutes)
IDLE_THRESHOLD_MINUTES=15
IDLE_CHECK_INTERVAL_SECONDS=60
SSH_READY_TIMEOUT_SECONDS=120

# Spring profile (prod toggles application-prod.yml)
SPRING_PROFILES_ACTIVE=prod
